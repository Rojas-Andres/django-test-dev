# ------------------------------------------------------------------
# Copy this file to `.env` (and `.envrc`) and fill in the values.
#   cp .env.example .env
#   cp .env.example .envrc
# `.env`   -> read by docker compose for variable substitution.
# `.envrc` -> loaded inside the worker container (env_file in compose).
# ------------------------------------------------------------------

# Django
DJANGO_SETTINGS_MODULE=django_project.settings.dev
SECRET_KEY=change-me
ENVIRONMENT=dev

# Tells the entrypoint to wait for postgres before starting.
DATABASE=postgres

# PostgreSQL connection (used by Django, settings/dev.py)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=tasks_db
DATABASE_USER=tasks_user
DATABASE_PASSWORD=tasks_password

# Host port to expose postgres on (docker-compose interpolation)
POSTGRES_PORT_COMPOSE_EXPORT=5432

# Redis (cache)
REDIS_HOSTNAME=redis
REDIS_PORT=6379
CACHEOPS_ENABLED=0

# "Upcoming tasks" window, in days (endpoint GET /api/task/upcoming/)
TASK_UPCOMING_DEFAULT_DAYS=7
