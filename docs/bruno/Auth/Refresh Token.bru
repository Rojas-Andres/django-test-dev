meta {
  name: Refresh Token
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/auth/token/refresh/
  body: json
  auth: none
}

body:json {
  {
    "refresh": "{{refresh_token}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("access_token", res.body.access);
  }
}

docs {
  Exchanges a valid `refresh` token for a new `access` token.
}
