{
  "info": {
    "name": "Tasks API - Prueba Tecnica",
    "description": "Coleccion para la API REST de gestion de tareas (Django + DRF + PostgreSQL).\n\nVariables de entorno:\n- base_url: por defecto http://localhost:8000\n- task_id: id de una tarea creada (se puede fijar tras el POST de creacion).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "task_id", "value": "1" }
  ],
  "item": [
    {
      "name": "1. Crear tarea (POST)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/task/", "host": ["{{base_url}}"], "path": ["api", "task", ""] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Escribir informe\",\n  \"description\": \"Informe trimestral Q3\",\n  \"status\": \"pendiente\",\n  \"due_date\": \"2026-12-31T23:59:00Z\",\n  \"created_by_name\": \"Andres\"\n}"
        }
      }
    },
    {
      "name": "2. Listar tareas (GET)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/task/list/?ordering=due_date",
          "host": ["{{base_url}}"],
          "path": ["api", "task", "list", ""],
          "query": [
            { "key": "ordering", "value": "due_date" },
            { "key": "status", "value": "pendiente", "disabled": true },
            { "key": "search", "value": "informe", "disabled": true },
            { "key": "due_date_after", "value": "2026-01-01T00:00:00Z", "disabled": true },
            { "key": "due_date_before", "value": "2026-12-31T23:59:59Z", "disabled": true }
          ]
        }
      }
    },
    {
      "name": "3. Actualizar tarea (PUT)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/task/{{task_id}}/", "host": ["{{base_url}}"], "path": ["api", "task", "{{task_id}}", ""] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Escribir informe final\",\n  \"description\": \"Version definitiva\",\n  \"status\": \"pendiente\",\n  \"due_date\": \"2026-12-31T23:59:00Z\",\n  \"created_by_name\": \"Andres\"\n}"
        }
      }
    },
    {
      "name": "4. Actualizar parcial (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/task/{{task_id}}/", "host": ["{{base_url}}"], "path": ["api", "task", "{{task_id}}", ""] },
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Titulo actualizado\"\n}" }
      }
    },
    {
      "name": "5. Cambiar estado (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/task/{{task_id}}/status/", "host": ["{{base_url}}"], "path": ["api", "task", "{{task_id}}", "status", ""] },
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"completada\"\n}" }
      }
    },
    {
      "name": "6. Eliminar tarea (DELETE logico)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{base_url}}/api/task/{{task_id}}/", "host": ["{{base_url}}"], "path": ["api", "task", "{{task_id}}", ""] }
      }
    },
    {
      "name": "7. Tareas proximas a vencer (GET)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/task/upcoming/?days=7",
          "host": ["{{base_url}}"],
          "path": ["api", "task", "upcoming", ""],
          "query": [{ "key": "days", "value": "7" }]
        }
      }
    }
  ]
}
